# data: the PDFs' translations are copyrighted (Ramakrishna Math, Advaita
# Ashram, Chinmaya Mission, etc.) — keep the corpora and anything derived from
# them out of any PUBLIC repo. Rebuild locally with:
#   python src/ingest.py && python src/ingest_ashtavakra.py && python src/index.py
108upanishads.pdf
ASHTAVAKRA_GITA.pdf
Srimad-Bhagavad-Gita-Shankara-Bhashya-English.pdf
# Ignore the raw PDFs and intermediate corpora, but KEEP the built Chroma vector
# DB so the app can run when deployed. NOTE: data/chroma still contains the
# copyrighted verse text — only commit it to a PRIVATE repo, never a public one.
data/*
!data/chroma/

